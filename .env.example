# ScanAdmin — variables d’environnement exemple
# Copier ce fichier en .env.local pour le développement local.
# Ne jamais commiter de vraies clés secrètes.

# -----------------------------------------------------------------------------
# Site public
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL="https://scanadmin.fr"

# -----------------------------------------------------------------------------
# Stripe Checkout — analyse personnalisée
# -----------------------------------------------------------------------------

# Clé secrète Stripe.
# Utiliser sk_test_... en test, puis sk_live_... en production.
STRIPE_SECRET_KEY="sk_test_..."

# Price ID Stripe pour l’analyse personnalisée ScanAdmin à 200 €.
# Exemple : price_123456789
STRIPE_ANALYSIS_PRICE_ID="price_..."

# Secret du webhook Stripe pour /api/stripe/webhook.
# Exemple : whsec_123456789
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Capture de leads — option webhook
# -----------------------------------------------------------------------------

# URL du webhook interne qui reçoit les demandes d’analyse.
# Laisser vide si vous utilisez uniquement Resend/email.
SCANADMIN_LEADS_WEBHOOK_URL=""

# Secret optionnel envoyé au webhook leads.
SCANADMIN_LEADS_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Capture de leads — option email via Resend
# -----------------------------------------------------------------------------

# Clé API Resend.
# Laisser vide si vous utilisez uniquement un webhook.
RESEND_API_KEY="re_..."

# Adresse qui reçoit les demandes de leads.
SCANADMIN_LEADS_TO_EMAIL="contact@scanadmin.fr"

# Adresse d’envoi utilisée par Resend.
# Le domaine doit être configuré et vérifié dans Resend.
SCANADMIN_LEADS_FROM_EMAIL="ScanAdmin <leads@scanadmin.fr>"

# -----------------------------------------------------------------------------
# Notifications paiements Stripe — option email
# -----------------------------------------------------------------------------

# Adresse qui reçoit les notifications de paiement confirmé.
SCANADMIN_PAYMENTS_TO_EMAIL="contact@scanadmin.fr"

# Adresse d’envoi utilisée pour les notifications de paiement.
SCANADMIN_PAYMENTS_FROM_EMAIL="ScanAdmin <paiements@scanadmin.fr>"

# -----------------------------------------------------------------------------
# Notifications paiements Stripe — option webhook
# -----------------------------------------------------------------------------

# URL du webhook interne qui reçoit les paiements confirmés.
# Laisser vide si vous utilisez uniquement Resend/email.
SCANADMIN_PAYMENTS_WEBHOOK_URL=""

# Secret optionnel envoyé au webhook paiements.
SCANADMIN_PAYMENTS_WEBHOOK_SECRET=""
